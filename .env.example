# OpenAI API Key (optional - for GPT-powered answers)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# LLM Provider Configuration
# Options: openai, huggingface, template
LLM_PROVIDER=openai

# LLM Model Name
# OpenAI options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
# HuggingFace options: mistralai/Mistral-7B-Instruct-v0.2, etc.
LLM_MODEL=gpt-3.5-turbo

# Vector Store Path (optional - defaults to data/vectors)
# VECTOR_STORE_PATH=/path/to/custom/vector/store

# macOS Settings (prevent tokenizer multiprocessing issues)
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
